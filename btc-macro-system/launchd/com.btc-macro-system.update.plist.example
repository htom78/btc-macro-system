<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>local.btc-macro-system.update</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Volumes/PortableSSD/Projects/Claude_Projects/投资思考/btc-macro-system/scripts/update_once.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Volumes/PortableSSD/Projects/Claude_Projects/投资思考/btc-macro-system</string>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>10</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/Volumes/PortableSSD/Projects/Claude_Projects/投资思考/btc-macro-system/logs/update.log</string>
  <key>StandardErrorPath</key>
  <string>/Volumes/PortableSSD/Projects/Claude_Projects/投资思考/btc-macro-system/logs/update.err</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
